<!-- contacta_5.njk -->
<section class="contacta-5-section bg-light front-section pbr-120 ptr-120" data-scroll-section>

  <!-- Título -->
  <div class="container-global-3 mx-auto pb-64">
    <div class="row">
      <div class="col-xs-12 col-md-8">
        <div class="text-18-r c-accent mb-16">{{global_index.contacta_5_title}}</div>
        <div class="fluid-4-b mb-8">Tres sedes en el Baix Llobregat</div>
        <p class="p1" style="opacity:0.6">Una matrícula gratuita, acceso a todas. Elige la que tengas más cerca.</p>
      </div>
    </div>
  </div>

  <!-- Panel: tarjetas + mapa interactivo -->
  <div class="container-global-3 mx-auto">
    <div class="c5-panel" id="c5-panel">

      <!-- Columna izquierda: tarjetas de sedes -->
      <div class="c5-cards-col">

        <!-- SEDE 01 — HOSPITALET -->
        <div class="c5-card c5-card--active" data-sede="1" onclick="selectSede(1)">
          <div class="c5-card-head">
            <span class="c5-card-num">01</span>
            <div>
              <span class="c5-card-tag">Sede principal</span>
              <h3 class="c5-card-nombre">L'Hospitalet de Llobregat</h3>
            </div>
          </div>
          <p class="c5-card-dir">
            Casino del Centre<br>
            C/ D'Enric Prat de la Riba, 337<br>
            08901 L'Hospitalet de Llobregat
          </p>
          <div class="c5-card-horarios">
            <div class="c5-hrow">
              <span class="c5-badge c5-badge--salsa">Salsa</span>
              <span>19:00 — 22:00 h</span>
            </div>
            <div class="c5-hrow">
              <span class="c5-badge c5-badge--bachata">Bachata</span>
              <span>18:00 — 21:00 h</span>
            </div>
          </div>
          <div class="c5-card-actions">
            <a class="c5-btn-maps"
               href="https://maps.google.com/?q=Casino+del+Centre,+Carrer+Enric+Prat+de+la+Riba+337,+L%27Hospitalet+de+Llobregat"
               target="_blank" rel="noopener noreferrer"
               onclick="event.stopPropagation()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M17 9.5C17 13.6421 12 19 12 19C12 19 7 13.6421 7 9.5C7 6.46243 9.23858 4 12 4C14.7614 4 17 6.46243 17 9.5Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><circle cx="12" cy="9.5" r="2" stroke="currentColor" stroke-width="1.8"/></svg>
              Abrir en Google Maps
            </a>
            <a class="c5-btn-ig"
               href="https://www.instagram.com/hospitalet_baila_casino"
               target="_blank" rel="noopener noreferrer"
               onclick="event.stopPropagation()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
              @hospitalet_baila_casino
            </a>
          </div>
        </div>

        <!-- SEDE 02 — SANT JOAN DESPÍ -->
        <div class="c5-card" data-sede="2" onclick="selectSede(2)">
          <div class="c5-card-head">
            <span class="c5-card-num">02</span>
            <div>
              <span class="c5-card-tag">Sede 2</span>
              <h3 class="c5-card-nombre">Sant Joan Despí</h3>
            </div>
          </div>
          <p class="c5-card-dir">
            Sant Joan Despí<br>
            Barcelona
          </p>
          <div class="c5-card-horarios">
            <div class="c5-hrow">
              <span class="c5-badge c5-badge--salsa">Salsa</span>
              <span>Consultar horarios</span>
            </div>
            <div class="c5-hrow">
              <span class="c5-badge c5-badge--bachata">Bachata</span>
              <span>Consultar horarios</span>
            </div>
          </div>
          <div class="c5-card-actions">
            <a class="c5-btn-maps"
               href="https://maps.google.com/?q=Sant+Joan+Despi,+Barcelona"
               target="_blank" rel="noopener noreferrer"
               onclick="event.stopPropagation()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M17 9.5C17 13.6421 12 19 12 19C12 19 7 13.6421 7 9.5C7 6.46243 9.23858 4 12 4C14.7614 4 17 6.46243 17 9.5Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><circle cx="12" cy="9.5" r="2" stroke="currentColor" stroke-width="1.8"/></svg>
              Abrir en Google Maps
            </a>
            <a class="c5-btn-ig"
               href="https://www.instagram.com/despi_baila_casino"
               target="_blank" rel="noopener noreferrer"
               onclick="event.stopPropagation()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
              @despi_baila_casino
            </a>
          </div>
        </div>

        <!-- SEDE 03 — SANT BOI -->
        <div class="c5-card" data-sede="3" onclick="selectSede(3)">
          <div class="c5-card-head">
            <span class="c5-card-num">03</span>
            <div>
              <span class="c5-card-tag">Sede 3</span>
              <h3 class="c5-card-nombre">Sant Boi de Llobregat</h3>
            </div>
          </div>
          <p class="c5-card-dir">
            Sant Boi de Llobregat<br>
            Barcelona
          </p>
          <div class="c5-card-horarios">
            <div class="c5-hrow">
              <span class="c5-badge c5-badge--salsa">Salsa</span>
              <span>Consultar horarios</span>
            </div>
            <div class="c5-hrow">
              <span class="c5-badge c5-badge--bachata">Bachata</span>
              <span>Consultar horarios</span>
            </div>
          </div>
          <div class="c5-card-actions">
            <a class="c5-btn-maps"
               href="https://maps.google.com/?q=Sant+Boi+de+Llobregat,+Barcelona"
               target="_blank" rel="noopener noreferrer"
               onclick="event.stopPropagation()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M17 9.5C17 13.6421 12 19 12 19C12 19 7 13.6421 7 9.5C7 6.46243 9.23858 4 12 4C14.7614 4 17 6.46243 17 9.5Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><circle cx="12" cy="9.5" r="2" stroke="currentColor" stroke-width="1.8"/></svg>
              Abrir en Google Maps
            </a>
            <a class="c5-btn-ig"
               href="https://www.instagram.com/santboi_baila_casino"
               target="_blank" rel="noopener noreferrer"
               onclick="event.stopPropagation()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
              @santboi_baila_casino
            </a>
          </div>
        </div>

      </div>
      <!-- fin c5-cards-col -->

      <!-- Columna derecha: mapa -->
      <div class="c5-map-col">

        <!-- Mapa sede 01 — Casino del Centre, Hospitalet -->
        <div class="c5-map c5-map--active" id="c5-map-1">
          <iframe
            src="https://maps.google.com/maps?q=41.36210,2.11180&z=17&output=embed&hl=es"
            width="100%" height="100%" style="border:0; display:block;"
            allowfullscreen="" loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Casino del Centre — L'Hospitalet de Llobregat"></iframe>
        </div>

        <!-- Mapa sede 02 — Sant Joan Despí -->
        <div class="c5-map" id="c5-map-2">
          <iframe
            src="https://maps.google.com/maps?q=Sant+Joan+Despi,+Barcelona&z=14&output=embed&hl=es"
            width="100%" height="100%" style="border:0; display:block;"
            allowfullscreen="" loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Sant Joan Despí"></iframe>
        </div>

        <!-- Mapa sede 03 — Sant Boi de Llobregat -->
        <div class="c5-map" id="c5-map-3">
          <iframe
            src="https://maps.google.com/maps?q=Sant+Boi+de+Llobregat,+Barcelona&z=14&output=embed&hl=es"
            width="100%" height="100%" style="border:0; display:block;"
            allowfullscreen="" loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Sant Boi de Llobregat"></iframe>
        </div>

      </div>
      <!-- fin c5-map-col -->

    </div>
    <!-- fin c5-panel -->
  </div>

</section>

<script>
function selectSede(num) {
  // Tarjetas
  document.querySelectorAll('.c5-card').forEach(function(card) {
    card.classList.remove('c5-card--active');
  });
  document.querySelector('[data-sede="' + num + '"]').classList.add('c5-card--active');

  // Mapas
  document.querySelectorAll('.c5-map').forEach(function(map) {
    map.classList.remove('c5-map--active');
  });
  document.getElementById('c5-map-' + num).classList.add('c5-map--active');
}
</script>
